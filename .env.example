# Django Configuration
DEBUG=True
SECRET_KEY=your-secret-key-here-generate-with-python-manage-py-generatesecretkey
ALLOWED_HOSTS=localhost,127.0.0.1,your-ip-address

# Database Configuration
DATABASE_URL=postgresql://videostudio:your-postgres-password@postgres:5432/video_studio
POSTGRES_DB=video_studio
POSTGRES_USER=videostudio
POSTGRES_PASSWORD=your-postgres-password

# CORS Configuration
CORS_ALLOWED_ORIGINS=https://your-ip-address,http://your-ip-address,https://localhost,http://localhost

# Frontend Configuration
REACT_APP_API_URL=https://your-ip-address/api

# Security Configuration
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Logging Configuration
LOG_LEVEL=INFO
LOG_MAX_SIZE=10MB
LOG_BACKUP_COUNT=5

# Video Configuration
MAX_VIDEO_SIZE=100MB
MAX_VIDEOS_PER_USER=3
VIDEO_EXPIRATION_DAYS=15

# SSL Configuration (for development)
SSL_CERT_PATH=./certs/cert.pem
SSL_KEY_PATH=./certs/key.pem
